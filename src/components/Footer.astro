---

<footer
  class="border-t mt-auto"
  style="border-color: var(--color-border-subtle); background: var(--color-surface);"
>
  <div class="site-container py-12 flex flex-col gap-8">
    <!-- Socials row -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <a
        href="/"
        class="font-display text-lg font-bold tracking-widest uppercase"
        style="letter-spacing: 0.2em;"
      >
        KISANII
      </a>

      <div class="flex items-center gap-5">
        {
          socials.map(({ label, href, icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="transition-colors"
              style="color: var(--color-fg-muted);"
              onmouseover="this.style.color='var(--color-accent)'"
              onmouseout="this.style.color='var(--color-fg-muted)'"
            >
              <Fragment set:html={icon} />
            </a>
          ))
        }
      </div>
    </div>

    <hr class="divider" />

    <!-- Bottom row -->
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-3 text-xs"
      style="color: var(--color-fg-muted);"
    >
      <span>{t(lang, 'footer.copyright')} {new Date().getFullYear()}</span>
      <a
        href={`mailto:${t(lang, 'contact.email')}`}
        class="transition-colors hover:text-accent"
        style="color: var(--color-fg-muted);"
      >
        {t(lang, 'contact.email')}
      </a>
    </div>
  </div>
</footer>
