---
import { t, withBase, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  date: Date;
  summary: string;
  slug: string;
  externalUrl?: string;
}

const { lang, title, date, summary, slug, externalUrl } = Astro.props;

const newsBasePath = lang === 'de' ? '/news/' : '/en/news/';
const detailUrl = withBase(`${newsBasePath}${slug}`);

const formattedDate = date.toLocaleDateString(lang === 'de' ? 'de-CH' : 'en-GB', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<article
  class="card p-6 flex flex-col gap-3 hover:border-accent transition-colors group"
  style="border-color: var(--color-border-subtle);"
>
  <time
    datetime={date.toISOString().slice(0, 10)}
    class="text-xs uppercase tracking-widest"
    style="color: var(--color-fg-muted);"
  >
    {formattedDate}
  </time>

  <h3 class="font-display text-lg font-semibold leading-snug group-hover:text-accent transition-colors">
    <a href={detailUrl}>{title}</a>
  </h3>

  <p class="text-sm leading-relaxed line-clamp-3" style="color: var(--color-fg-muted);">
    {summary}
  </p>

  <div class="flex items-center gap-4 mt-auto pt-2">
    <a
      href={detailUrl}
      class="text-xs uppercase tracking-widest transition-colors"
      style="color: var(--color-accent);"
    >
      {t(lang, 'news.readmore')} →
    </a>
    {
      externalUrl && (
        <a
          href={externalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs uppercase tracking-widest transition-colors"
          style="color: var(--color-fg-muted);"
        >
          {t(lang, 'news.external')}
        </a>
      )
    }
  </div>
</article>
