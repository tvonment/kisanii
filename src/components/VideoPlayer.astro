---
interface Props {
  /**
   * Path to the MP4 source (in /public/video/). WebM with same basename is used as fallback.
   * Example: "/video/epk.mp4"
   */
  src: string;
  poster?: string;
  /** Path to a WebVTT subtitle file, e.g. "/video/epk.en.vtt" */
  trackSrc?: string;
  class?: string;
  lang?: 'de' | 'en';
}

const { src, poster, trackSrc, class: className, lang = 'de' } = Astro.props;
const unmuteLabel = lang === 'en' ? 'Enable sound' : 'Sound einschalten';
const replayLabel = lang === 'en' ? 'Replay' : 'Nochmal';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const srcWithBase = base + src;
const webmSrcWithBase = base + src.replace(/\.mp4$/, '.webm');
const trackSrcWithBase = trackSrc ? base + trackSrc : undefined;
const videoId = `vp-${Math.random().toString(36).slice(2, 9)}`;
---

<div class:list={['video-wrapper', className]}>
  <video
    id={videoId}
    autoplay
    muted
    playsinline
    preload="metadata"
    poster={poster}
    aria-label="EPK video"
  >
    <source src={webmSrcWithBase} type="video/webm" />
    <source src={srcWithBase} type="video/mp4" />
    {trackSrcWithBase && <track kind="subtitles" src={trackSrcWithBase} srclang="en" label="English" default />}
  </video>

  <!-- Click-to-unmute overlay -->
  <div
    id={`${videoId}-overlay`}
    class="absolute inset-0 flex flex-col items-center justify-center cursor-pointer"
    style="background: linear-gradient(to top, rgba(14,11,11,0.55) 0%, transparent 60%);"
    role="button"
    aria-label="Click to unmute"
  >
    <div class="flex flex-col items-center gap-3 mt-auto mb-10">
      <div
        class="w-16 h-16 rounded-full flex items-center justify-center"
        style="background: var(--color-accent); box-shadow: 0 0 0 6px rgba(234,102,50,0.25); font-size: 1.5rem;"
      >
        <i class="fa-solid fa-volume-high" style="color: #fff;"></i>
      </div>
      <span
        class="text-xs uppercase tracking-[0.25em] font-semibold px-4 py-1.5 rounded-full"
        style="background: rgba(14,11,11,0.7); color: var(--color-fg);"
      >{unmuteLabel}</span>
    </div>
  </div>

  <!-- End-of-video replay overlay -->
  <div
    id={`${videoId}-replay`}
    class="absolute inset-0 flex items-center justify-center cursor-pointer"
    style="background: rgba(14,11,11,0.65); display: none;"
    role="button"
    aria-label="Replay video"
  >
    <div class="flex flex-col items-center gap-3">
      <div
        class="w-16 h-16 rounded-full flex items-center justify-center"
        style="background: var(--color-accent); box-shadow: 0 0 0 6px rgba(234,102,50,0.25); font-size: 1.5rem;"
      >
        <i class="fa-solid fa-rotate-left" style="color: #fff;"></i>
      </div>
      <span
        class="text-xs uppercase tracking-[0.25em] font-semibold px-4 py-1.5 rounded-full"
        style="background: rgba(14,11,11,0.7); color: var(--color-fg);"
      >{replayLabel}</span>
    </div>
  </div>

  <!-- Corner controls -->
  <div class="absolute bottom-4 right-4 flex gap-2">
    <!-- Restart button -->
    <button
      id={`${videoId}-restart`}
      class="flex items-center gap-1.5 px-3 py-1.5 rounded text-xs uppercase tracking-widest transition-all"
      style="background: rgba(14,11,11,0.75); color: var(--color-fg); border: 1px solid var(--color-border);"
      aria-label="Restart video"
    >
      <i class="fa-solid fa-rotate-left"></i>
    </button>
    <!-- Mute toggle -->
    <button
      id={`${videoId}-unmute`}
      class="flex items-center gap-2 px-3 py-1.5 rounded text-xs uppercase tracking-widest transition-all"
      style="background: rgba(14,11,11,0.75); color: var(--color-fg); border: 1px solid var(--color-border);"
      aria-label="Unmute video"
      aria-pressed="false"
    >
      <i id={`${videoId}-icon`} class="fa-solid fa-volume-xmark"></i>
      <span>Sound</span>
    </button>
  </div>
</div>

<script is:inline define:vars={{ videoId }}>
  const video = document.getElementById(videoId);
  const btn = document.getElementById(`${videoId}-unmute`);
  const icon = document.getElementById(`${videoId}-icon`);
  const overlay = document.getElementById(`${videoId}-overlay`);
  const replayOverlay = document.getElementById(`${videoId}-replay`);
  const restartBtn = document.getElementById(`${videoId}-restart`);

  if (!video || !btn || !icon) return;

  // IntersectionObserver: play when in viewport, pause otherwise
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    },
    { threshold: 0.4 },
  );

  observer.observe(video);

  function unmute() {
    video.muted = false;
    icon.className = 'fa-solid fa-volume-high';
    btn.setAttribute('aria-pressed', 'true');
    btn.setAttribute('aria-label', 'Mute video');
    if (overlay) overlay.style.display = 'none';
    video.play().catch(() => {});
  }

  function restart() {
    video.currentTime = 0;
    video.play().catch(() => {});
    if (replayOverlay) replayOverlay.style.display = 'none';
    if (overlay) overlay.style.display = 'none';
  }

  // Click-to-unmute overlay
  if (overlay) {
    overlay.addEventListener('click', unmute);
  }

  // End-of-video: show replay overlay
  video.addEventListener('ended', () => {
    if (replayOverlay) replayOverlay.style.display = 'flex';
  });

  // Replay overlay click
  if (replayOverlay) {
    replayOverlay.addEventListener('click', restart);
  }

  // Corner restart button
  if (restartBtn) {
    restartBtn.addEventListener('click', restart);
  }

  // Corner mute toggle
  btn.addEventListener('click', () => {
    if (overlay) overlay.style.display = 'none';
    video.muted = !video.muted;
    const muted = video.muted;
    icon.className = muted ? 'fa-solid fa-volume-xmark' : 'fa-solid fa-volume-high';
    btn.setAttribute('aria-pressed', String(!muted));
    btn.setAttribute('aria-label', muted ? 'Unmute video' : 'Mute video');
  });
</script>
