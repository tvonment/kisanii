---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import NewsCard from '../components/NewsCard.astro';
import ConcertRow from '../components/ConcertRow.astro';
import { t } from '../i18n/ui';
import { upcomingConcerts, pastConcerts } from '../data/concerts';

const lang = 'de';
const newsEntries = await getCollection('newsDE');
const latestNews = newsEntries
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const description =
  'Kisanii – Schweizer Singer-Songwriterin. Verletzlich, authentisch, unaufhaltsam ehrlich. Aktuelle Konzerte, News und mehr.';
---

<BaseLayout title="KISANII" description={description} lang={lang}>
  <!-- ── HERO ──────────────────────────────────────────────── -->
  <section
    class="relative flex flex-col justify-center min-h-[80svh] section-gap"
    style="background: radial-gradient(ellipse at 60% 40%, rgba(234,102,50,0.08) 0%, transparent 60%);"
  >
    <div class="site-container flex flex-col gap-8">
      <div class="flex flex-col gap-4 max-w-2xl">
        <h1
          class="font-display text-6xl sm:text-8xl md:text-9xl font-bold leading-none tracking-tight"
          style="letter-spacing: -0.02em;"
        >
          KISANII
        </h1>
        <p class="text-lg sm:text-xl max-w-xl leading-relaxed" style="color: var(--color-fg-muted);">
          Verletzlich, authentisch, unaufhaltsam ehrlich.
        </p>
      </div>

      <div class="flex flex-wrap gap-4">
        <a href="#aktuelles" class="btn btn-accent">Neuigkeiten</a>
        <a href="#live" class="btn btn-outline">Konzerte</a>
      </div>

      <!-- Streaming links row -->
      <div class="flex flex-wrap gap-3 mt-4">
        <a
          href="https://open.spotify.com/artist/7jMnqSsKuIzLzjgIPtgbwu"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline text-xs"
        >
          Spotify
        </a>
        <a
          href="https://music.apple.com/nl/artist/kisanii/1727114509"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline text-xs"
        >
          Apple Music
        </a>
        <a
          href="https://linktr.ee/kisanii"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline text-xs"
        >
          Alle Plattformen
        </a>
      </div>
    </div>
  </section>

  <!-- ── BIO ───────────────────────────────────────────────── -->
  <section id="bio" class="section-gap" style="background: var(--color-surface);">
    <div class="site-container">
      <SectionHeading text={t(lang, 'section.bio')} />
      <div class="max-w-2xl">
        <p class="text-base sm:text-lg leading-relaxed" style="color: var(--color-fg-muted);">
          {t(lang, 'bio.text')}
        </p>
      </div>
    </div>
  </section>

  <!-- ── NEWS ──────────────────────────────────────────────── -->
  <section id="aktuelles" class="section-gap">
    <div class="site-container">
      <SectionHeading text={t(lang, 'section.news')} id="aktuelles-heading" />
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {
          latestNews.map((entry) => (
            <NewsCard
              lang={lang}
              title={entry.data.title}
              date={entry.data.date}
              summary={entry.data.summary}
              slug={entry.id}
              externalUrl={entry.data.externalUrl}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── LIVE ──────────────────────────────────────────────── -->
  <section id="live" class="section-gap" style="background: var(--color-surface);">
    <div class="site-container">
      <SectionHeading text={t(lang, 'section.live')} />

      {
        upcomingConcerts.length > 0 ? (
          <div class="mb-12">
            <h3 class="text-xs uppercase tracking-widest mb-4" style="color: var(--color-fg-muted);">
              {t(lang, 'concerts.upcoming')}
            </h3>
            <div>
              {upcomingConcerts.map((c) => (
                <ConcertRow concert={c} lang={lang} />
              ))}
            </div>
          </div>
        ) : (
          <p class="mb-12 text-sm" style="color: var(--color-fg-muted);">
            {t(lang, 'concerts.none')}
          </p>
        )
      }

      <!-- Past concerts (collapsible) -->
      <details class="group">
        <summary
          class="cursor-pointer text-xs uppercase tracking-widest select-none list-none flex items-center gap-2 mb-4"
          style="color: var(--color-fg-muted);"
        >
          <span
            class="transition-transform group-open:rotate-90 inline-block"
            aria-hidden="true">▶</span
          >
          {t(lang, 'concerts.past')} ({pastConcerts.length})
        </summary>
        <div>
          {pastConcerts.map((c) => <ConcertRow concert={c} lang={lang} />)}
        </div>
      </details>
    </div>
  </section>

  <!-- ── KONTAKT / NEWSLETTER ──────────────────────────────── -->
  <section id="kontakt" class="section-gap">
    <div class="site-container">
      <SectionHeading text={t(lang, 'section.contact')} />
      <div class="flex flex-col sm:flex-row gap-12 max-w-2xl">
        <!-- Booking -->
        <div class="flex flex-col gap-3">
          <h3 class="font-display text-xl font-semibold">{t(lang, 'contact.booking')}</h3>
          <p class="text-sm" style="color: var(--color-fg-muted);">{t(lang, 'contact.bookingdesc')}</p>
          <a
            href="mailto:booking@kisanii.ch"
            class="btn btn-accent self-start"
          >
            booking@kisanii.ch
          </a>
        </div>

        <!-- Newsletter -->
        <div class="flex flex-col gap-3">
          <h3 class="font-display text-xl font-semibold">{t(lang, 'section.newsletter')}</h3>
          <p class="text-sm" style="color: var(--color-fg-muted);">{t(lang, 'newsletter.desc')}</p>
          <form
            action="https://kisanii.us16.list-manage.com/subscribe/post?u=3d23a4c57b3ae204454609652&id=468b01f4ba&f_id=0033a2e1f0"
            method="post"
            target="_blank"
            class="flex flex-col sm:flex-row gap-3 mt-1"
          >
            <input
              type="email"
              name="EMAIL"
              required
              autocomplete="email"
              placeholder={t(lang, 'newsletter.email')}
              class="px-4 py-2.5 rounded text-sm w-full sm:w-64 outline-none focus:ring-2"
              style="background: var(--color-surface-raised); border: 1px solid var(--color-border); color: var(--color-fg); --tw-ring-color: var(--color-accent);"
            />
            {/* Honeypot — must stay hidden */}
            <div style="position:absolute;left:-5000px;" aria-hidden="true">
              <input type="text" name="b_3d23a4c57b3ae204454609652_468b01f4ba" tabindex="-1" value="" />
            </div>
            <button type="submit" class="btn btn-accent shrink-0">
              {t(lang, 'newsletter.subscribe')}
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
