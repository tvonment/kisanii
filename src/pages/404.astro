---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, withBase } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
---

<BaseLayout title="404 – Seite nicht gefunden" lang={lang}>
  <section class="section-gap flex flex-col items-center justify-center text-center min-h-[60vh]">
    <div class="site-container flex flex-col items-center gap-6 max-w-lg">
      <p class="font-display text-8xl font-bold" style="color: var(--color-accent);">404</p>
      <h1 class="font-display text-2xl font-semibold">
        {lang === 'de' ? 'Seite nicht gefunden' : 'Page not found'}
      </h1>
      <p style="color: var(--color-fg-muted);" class="text-sm">
        {
          lang === 'de'
            ? 'Diese Seite existiert leider nicht. Vielleicht wurde sie verschoben oder gelöscht.'
            : 'This page does not exist. It may have been moved or deleted.'
        }
      </p>
      <a href={withBase(lang === 'de' ? '/' : '/en/')} class="btn btn-accent">
        {lang === 'de' ? 'Zurück zur Startseite' : 'Back to homepage'}
      </a>
    </div>
  </section>
</BaseLayout>
