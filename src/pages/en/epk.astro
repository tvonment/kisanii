---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import VideoPlayer from '../../components/VideoPlayer.astro';
import ConcertRow from '../../components/ConcertRow.astro';
import { t } from '../../i18n/ui';
import { upcomingConcerts, pastConcerts } from '../../data/concerts';

const lang = 'en';

const releases = [
  {
    title: 'Cycle',
    type: 'EP · 3 Tracks',
    year: '2025',
    seed: 'kisanii-cycle',
    link: 'https://open.spotify.com/artist/7jMnqSsKuIzLzjgIPtgbwu',
    linkLabel: 'Listen on Spotify →',
  },
  {
    title: 'Tailwind',
    type: 'Single',
    year: '2024',
    seed: 'kisanii-tailwind',
    link: 'https://open.spotify.com/artist/7jMnqSsKuIzLzjgIPtgbwu',
    linkLabel: 'Listen on Spotify →',
  },
  {
    title: 'Victress',
    type: 'Single + Music Video',
    year: '2024',
    seed: 'kisanii-victress',
    link: 'https://www.youtube.com/@kisanii4729',
    linkLabel: 'Watch on YouTube →',
  },
];
---

<BaseLayout
  title={t(lang, 'epk.title')}
  description={t(lang, 'epk.description')}
  noindex={true}
  lang={lang}
>
  <!-- ── VIDEO ─────────────────────────────────────────────── -->
  <section class="section-gap" style="background: var(--color-bg);">
    <div class="site-container">
      <div class="text-center max-w-2xl mx-auto mb-8 flex flex-col gap-3">
        <p class="text-xs uppercase tracking-[0.3em] font-semibold" style="color: var(--color-accent);">
          Electronic Press Kit
        </p>
        <h1 class="font-display text-4xl sm:text-5xl font-bold">KISANII</h1>
        <p class="text-base leading-relaxed" style="color: var(--color-fg-muted);">
          {t(lang, 'epk.subtitle')}
        </p>
      </div>
      <VideoPlayer src="/video/epk.mp4" trackSrc="/video/epk.en.vtt" class="max-w-4xl mx-auto" />
    </div>
  </section>

  <!-- ── KEY FACTS ──────────────────────────────────────────── -->
  <section style="background: var(--color-surface);">
    <div class="site-container py-8">
      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-6">
        {
          [
            { label: 'Origin', value: 'Switzerland' },
            { label: 'Genre', value: 'Singer-Songwriter' },
            { label: 'Language', value: 'German' },
            { label: 'Label', value: 'Independent' },
          ].map(({ label, value }) => (
            <div class="flex flex-col gap-1">
              <dt class="text-xs uppercase tracking-widest" style="color: var(--color-fg-muted);">
                {label}
              </dt>
              <dd class="font-display text-lg font-semibold">{value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- ── BIO ────────────────────────────────────────────────── -->
  <section class="section-gap">
    <div class="site-container">
      <SectionHeading text={t(lang, 'section.bio')} />
      <div class="grid md:grid-cols-2 gap-12 max-w-4xl items-start">
        <div class="flex flex-col gap-5">
          <p class="text-base leading-relaxed" style="color: var(--color-fg-muted);">
            {t(lang, 'bio.text')}
          </p>
          <p class="text-base leading-relaxed" style="color: var(--color-fg-muted);">
            With her debut EP <strong style="color: var(--color-fg);">«Cycle»</strong> (2025) and
            singles <strong style="color: var(--color-fg);">«Tailwind»</strong> and
            <strong style="color: var(--color-fg);">«Victress»</strong>, she has built a devoted
            following and attracted media attention — including a feature on Swiss Radio SR in
            April 2025.
          </p>
          <div class="flex flex-wrap gap-3 mt-1">
            <a
              href="https://open.spotify.com/artist/7jMnqSsKuIzLzjgIPtgbwu"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline text-xs">Spotify</a>
            <a
              href="https://music.apple.com/nl/artist/kisanii/1727114509"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline text-xs">Apple Music</a>
            <a
              href="https://www.instagram.com/kisanii.music/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline text-xs">Instagram</a>
          </div>
        </div>
        <div class="relative rounded-lg overflow-hidden" style="aspect-ratio: 3/4;">
          <img
            src="https://picsum.photos/seed/kisanii-portrait/500/667"
            alt="Kisanii – Press photo (placeholder)"
            class="w-full h-full object-cover"
            loading="lazy"
          />
          <p
            class="absolute bottom-3 right-3 text-xs px-2 py-1 rounded"
            style="background: rgba(14,11,11,0.75); color: var(--color-fg-muted);"
          >
            Press photo coming soon
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── MUSIC ──────────────────────────────────────────────── -->
  <section class="section-gap" style="background: var(--color-surface);">
    <div class="site-container">
      <SectionHeading text="Music" />
      <div class="grid sm:grid-cols-3 gap-6 max-w-3xl">
        {
          releases.map(({ title, type, year, seed, link, linkLabel }) => (
            <div class="card overflow-hidden flex flex-col">
              <div class="overflow-hidden" style="aspect-ratio: 1;">
                <img
                  src={`https://picsum.photos/seed/${seed}/400/400`}
                  alt={`${title} – Artwork placeholder`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="p-4 flex flex-col gap-1 flex-1">
                <p class="text-xs uppercase tracking-widest" style="color: var(--color-fg-muted);">
                  {type} · {year}
                </p>
                <h3 class="font-display text-lg font-semibold">{title}</h3>
                <a
                  href={link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs mt-auto pt-3 transition-colors"
                  style="color: var(--color-fg-muted);"
                >
                  {linkLabel}
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── PRESS ──────────────────────────────────────────────── -->
  <section class="section-gap">
    <div class="site-container">
      <SectionHeading text="Press & Media" />

      <blockquote
        class="card p-8 max-w-2xl mb-12 border-l-4"
        style="border-left-color: var(--color-accent);"
      >
        <p class="font-display text-xl font-medium leading-relaxed mb-4">
          «Kisanii takes her listeners on a journey — vulnerable, honest, and irresistibly authentic.»
        </p>
        <footer class="text-xs uppercase tracking-widest" style="color: var(--color-fg-muted);">
          Swiss Radio SR · April 2025
        </footer>
      </blockquote>

      <h3 class="text-xs uppercase tracking-widest mb-4" style="color: var(--color-fg-muted);">
        Press photos — hi-res images coming soon
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 max-w-3xl">
        {
          ['a', 'b', 'c'].map((s) => (
            <div class="rounded-lg overflow-hidden" style="aspect-ratio: 1;">
              <img
                src={`https://picsum.photos/seed/kisanii-press-${s}/400/400`}
                alt="Press photo placeholder"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── LIVE ───────────────────────────────────────────────── -->
  <section class="section-gap" style="background: var(--color-surface);">
    <div class="site-container">
      <SectionHeading text="Live" />
      {
        upcomingConcerts.length > 0 && (
          <div class="mb-10">
            <h3 class="text-xs uppercase tracking-widest mb-4" style="color: var(--color-fg-muted);">
              Upcoming
            </h3>
            <div>
              {upcomingConcerts.map((c) => (
                <ConcertRow concert={c} lang={lang} />
              ))}
            </div>
          </div>
        )
      }
      <h3 class="text-xs uppercase tracking-widest mb-4" style="color: var(--color-fg-muted);">
        Past Shows (selection)
      </h3>
      <div>
        {pastConcerts.slice(0, 8).map((c) => <ConcertRow concert={c} lang={lang} />)}
      </div>
    </div>
  </section>

  <!-- ── BOOKING ────────────────────────────────────────────── -->
  <section class="section-gap">
    <div class="site-container">
      <SectionHeading text={t(lang, 'epk.booking')} />
      <div class="card p-8 max-w-2xl flex flex-col gap-6">
        <p class="text-base leading-relaxed" style="color: var(--color-fg-muted);">
          For booking enquiries, interviews, hi-res press photos and any other information,
          the Kisanii team is happy to help.
        </p>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="flex flex-col gap-1">
            <span class="text-xs uppercase tracking-widest" style="color: var(--color-fg-muted);">Booking</span>
            <a
              href="mailto:booking@kisanii.ch"
              class="font-semibold transition-colors"
              style="color: var(--color-fg);"
            >booking@kisanii.ch</a>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-xs uppercase tracking-widest" style="color: var(--color-fg-muted);">Social Media</span>
            <a
              href="https://www.instagram.com/kisanii.music/"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold transition-colors"
              style="color: var(--color-fg);"
            >@kisanii.music</a>
          </div>
        </div>
        <a href="mailto:booking@kisanii.ch" class="btn btn-accent self-start">
          Send enquiry →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

