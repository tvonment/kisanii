---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t } from '../../../i18n/ui';

export async function getStaticPaths() {
  const entries = await getCollection('newsEN');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const lang = 'en';

const formattedDate = entry.data.date.toLocaleDateString('en-GB', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={entry.data.title} description={entry.data.summary} lang={lang}>
  <article class="section-gap">
    <div class="site-container max-w-2xl">
      <a
        href="/en/#news"
        class="inline-flex items-center gap-2 text-xs uppercase tracking-widest mb-8 transition-colors hover:text-accent"
        style="color: var(--color-fg-muted);"
      >
        ← {t(lang, 'news.back')}
      </a>

      <header class="flex flex-col gap-4 mb-10">
        <time
          datetime={entry.data.date.toISOString().slice(0, 10)}
          class="text-xs uppercase tracking-widest"
          style="color: var(--color-fg-muted);"
        >
          {formattedDate}
        </time>
        <h1 class="font-display text-3xl sm:text-4xl font-bold leading-tight">
          {entry.data.title}
        </h1>
        {
          entry.data.externalUrl && (
            <a
              href={entry.data.externalUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-accent self-start"
            >
              {t(lang, 'news.external')} ↗
            </a>
          )
        }
      </header>

      <hr class="divider mb-10" />

      <div class="prose">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
